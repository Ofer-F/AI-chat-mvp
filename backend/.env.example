# Server
PORT=3000
CORS_ORIGIN=http://localhost:5173

# Auth
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=1d

# Database
MONGO_URI=mongodb://localhost:27017/chat-mvp

# Seed demo users/conversations/messages on boot (dev/demo only). Default: false.
# Idempotent + non-destructive. Or run on demand with `npm run seed`.
SEED_DEMO_DATA=false
