# Server
PORT=3000
CORS_ORIGIN=http://localhost:5173

# Auth
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=1d

# Database
# MongoDB Atlas is REQUIRED for Vector Search (local Mongo does not support it).
# The DB name in the URI must match the database that holds the vector index.
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/AI-chat-MVP?appName=<app>

# OpenAI (AI Assistant + RAG embeddings)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# RAG / Atlas Vector Search
ATLAS_VECTOR_INDEX=knowledge_chunks_index
RAG_TOP_K=4

# Seed demo users/conversations/messages on boot (dev/demo only). Default: false.
# Idempotent + non-destructive. Or run on demand with `npm run seed`.
SEED_DEMO_DATA=false
