.env
.env.local
**/.env
!**/.env.example

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS / editor
.DS_Store
.idea/
*.sublime-workspace

# Local-only project notes (not for git)
PROJECT_CONTEXT.md
WEEK_7_PROJECT.md
